PORT=8080
RENDER_TIMEOUT_MS=180000
RENDER_CONCURRENCY=1
OFFTHREAD_VIDEO_THREADS=2
X264_PRESET=veryfast
CRF=23
# 1 = full resolution; 0.75 or 0.5 renders fewer pixels (much faster)
RENDER_SCALE=1
RENDER_IMAGE_FORMAT=jpeg
RENDER_JPEG_QUALITY=78
# disable | if-possible | required
HARDWARE_ACCELERATION=if-possible
# Pre-decode audio to stable WAV before Remotion mixes (recommended; set false to skip)
NORMALIZE_AUDIO=true
MEDIA_CACHE_TTL_MS=600000
# Delete rendered MP4 after upload (default: yes). Set to "false" to keep files under ./out
DELETE_OUTPUT_AFTER_RESPONSE=true
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_URL=https://your-api.com/webhooks/render-status

# Cloudflare R2 (required for upload)
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name

# Optional override for endpoint
# R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# Optional public URL base for uploaded object links in webhook payload
# Example: https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
R2_PUBLIC_BASE_URL=
